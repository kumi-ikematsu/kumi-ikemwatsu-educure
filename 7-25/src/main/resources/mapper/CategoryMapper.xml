<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="jp.educure.bookmanagement.mapper.CategoryMapper">

    <select id="findAll" resultType="jp.educure.bookmanagement.entity.Category">
        SELECT id, name, created_at AS createdAt
        FROM categories
        ORDER BY id
    </select>

    <select id="findById" parameterType="int" resultType="jp.educure.bookmanagement.entity.Category">
        SELECT id, name, created_at AS createdAt
        FROM categories
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="jp.educure.bookmanagement.entity.Category">
        INSERT INTO categories (name, created_at)
        VALUES (#{name}, NOW())
    </insert>

    <update id="update" parameterType="jp.educure.bookmanagement.entity.Category">
        UPDATE categories SET name = #{name} WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="int">
        DELETE FROM categories WHERE id = #{id}
    </delete>

    <delete id="deleteBookCategories" parameterType="int">
        DELETE FROM book_categories WHERE category_id = #{categoryId}
    </delete>

</mapper>
